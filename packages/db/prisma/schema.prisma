// =============================================================================
// EARLY ACCESS (platform-level waitlist / membership)
// =============================================================================

model EarlyAccessMember {
  id          String   @id @default(cuid())
  email       String   @unique
  name        String?
  company     String?
  websiteUrl  String?  // company website or X/Twitter URL
  role        String?  // organizer | sponsor | both
  referrer    String?  // utm_source or referring email
  utmSource   String?
  utmMedium   String?
  utmCampaign String?
  // Legal consent
  consentAt      DateTime?
  consentVersion String?
  // Referral tracking
  referralCode    String?  @unique @default(cuid()) // their shareable referral code
  referredByCode  String?                            // code they used when signing up
  // waitlisted | invited | onboarded
  status      String   @default("waitlisted")
  inviteCode  String?  @unique @default(cuid())
  invitedAt   DateTime?
  onboardedAt DateTime?
  // Admin workflow fields
  // new | reviewed | contacted | archived
  internalStatus String   @default("new")
  adminNotes     String?
  reviewedBy     String?
  reviewedAt     DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status])
  @@index([internalStatus])
  @@index([createdAt])
  @@map("early_access_members")
}

