  key       String
  enabled   Boolean  @default(false)
  config    Json?
  updatedBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, key])
  @@index([tenantId])
  @@map("feature_flags")
}

// =============================================================================
// M2A — PACKAGE-LEVEL ACCESS GRANTS
// =============================================================================

model ItemAccessGrant {
  id        String    @id @default(cuid())
  itemId    String
  grantType String    @default("email") // email | token
  email     String?
  token     String?   @unique
  usedAt    DateTime?
  expiresAt DateTime?
  createdBy String?
  createdAt DateTime  @default(now())

  item SponsorItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@unique([itemId, email])
  @@index([itemId])
  @@index([token])
  @@map("item_access_grants")
}

// =============================================================================
// M2B — KYC NOTES + AUDIT TRAIL
// =============================================================================

model KycNote {
  id           String        @id @default(cuid())
  submissionId String
  authorId     String
  authorName   String
  content      String
  isInternal   Boolean       @default(true)
  createdAt    DateTime      @default(now())

  submission KycSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@index([submissionId])
  @@map("kyc_notes")
}

// Chronological action trail for a KYC submission
model KycAuditEntry {
  id           String        @id @default(cuid())
  submissionId String
  // approved | rejected | needs_more_info | note_added | status_changed | form_sent | form_submitted
  action       String
  actorId      String?
  actorName    String
  fromStatus   String?
  toStatus     String?
  reason       String?
  metadata     Json?
  createdAt    DateTime      @default(now())

  submission KycSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@index([submissionId, createdAt])
  @@map("kyc_audit_entries")
}

// =============================================================================
// M2C — KYC FORM TEMPLATES (merchant-configurable, sent to sponsor)
// =============================================================================

model KycFormTemplate {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  description String?
  // Array of { id, type: text|textarea|file|select|checkbox, label, required, options?, placeholder? }
  fields      Json
  isActive    Boolean  @default(true)
  createdBy   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant   Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  requests KycFormRequest[]

  @@index([tenantId])
  @@map("kyc_form_templates")
}

// A form request sent from merchant to a specific sponsor for a deal
model KycFormRequest {
  id           String    @id @default(cuid())
  tenantId     String
  templateId   String
  submissionId String?   // optionally linked to a KycSubmission
  bidId        String?
  sentToEmail  String
  sentToName   String?
  token        String    @unique @default(cuid())
  // pending | submitted | reviewed
  status       String    @default("pending")
  response     Json?     // sponsor-submitted field answers
  submittedAt  DateTime?
  reviewedBy   String?
  reviewedAt   DateTime?
  reviewNotes  String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  template    KycFormTemplate  @relation(fields: [templateId], references: [id])
  submission  KycSubmission?   @relation(fields: [submissionId], references: [id])

  @@index([tenantId])
  @@index([token])
  @@index([bidId])
  @@map("kyc_form_requests")
}

// =============================================================================
// M4B — DEAL TEAM COLLABORATION
// =============================================================================

model DealMember {
  id        String   @id @default(cuid())
  bidId     String
  userId    String
  // owner | collaborator | viewer
  role      String   @default("collaborator")
  addedById String?
  createdAt DateTime @default(now())

  bid Bid @relation(fields: [bidId], references: [id], onDelete: Cascade)

  @@unique([bidId, userId])
  @@index([bidId])
  @@index([userId])
  @@map("deal_members")
}

// =============================================================================
// M6 — CROWDFUNDING VERIFICATION REQUESTS
// =============================================================================

model CrowdfundVerificationRequest {
  id          String    @id @default(cuid())
  campaignId  String
  requestedBy String
  // identity | document | context | other
  type        String    @default("context")
  description String
  // pending | submitted | reviewed
  status      String    @default("pending")
  response    String?
  respondedAt DateTime?
  createdAt   DateTime  @default(now())

  campaign CrowdfundCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId])
  @@map("crowdfund_verification_requests")
}

// =============================================================================
// PAYOUTS — merchant settlement ledger
// =============================================================================

model Payout {
  id          String    @id @default(cuid())
  tenantId    String
  status      String    @default("pending") // pending | processing | paid | failed | cancelled
  currency    String    @default("USD")
  grossAmount Decimal   @db.Decimal(12, 2)  // sum of merchantNetAmount for included orders
  feeAmount   Decimal   @default(0) @db.Decimal(12, 2) // any additional payout processing fee
  netAmount   Decimal   @db.Decimal(12, 2)  // grossAmount - feeAmount
  periodStart DateTime?
  periodEnd   DateTime?
  paidAt      DateTime?
  reference   String?   // external wire/transfer reference
  notes       String?
  metadata    Json?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  tenant Tenant      @relation(fields: [tenantId], references: [id])
  items  PayoutItem[]

  @@index([tenantId])
  @@index([status])
  @@map("payouts")
}

model PayoutItem {
  id        String   @id @default(cuid())
  payoutId  String
  orderId   String   @unique // each order can only appear in one payout
  amount    Decimal  @db.Decimal(12, 2) // merchantNetAmount from the order
  createdAt DateTime @default(now())

  payout Payout @relation(fields: [payoutId], references: [id], onDelete: Cascade)
  order  Order  @relation(fields: [orderId], references: [id])

  @@index([payoutId])
  @@map("payout_items")
}

// =============================================================================
// CUSTOM INVOICES — merchant-created invoices (standalone, not auto-generated)
// =============================================================================

model CustomInvoice {
  id               String    @id @default(cuid())
  tenantId         String
  invoiceNumber    String    @unique
  status           String    @default("draft") // draft | sent | paid | cancelled
  recipientEmail   String
  recipientName    String?
  recipientCompany String?
  currency         String    @default("USD")
  lines            Json      // [{label, quantity, unitPrice, total}]
  subtotal         Decimal   @db.Decimal(12, 2)
  taxRate          Decimal   @default(0) @db.Decimal(5, 4)
  taxAmount        Decimal   @default(0) @db.Decimal(12, 2)
  discountAmount   Decimal   @default(0) @db.Decimal(12, 2)
  total            Decimal   @db.Decimal(12, 2)
  dueDate          DateTime?
  notes            String?
  legalText        String?
  issuedAt         DateTime?
  paidAt           DateTime?
  orderId          String?   // optional link to auto-generated order
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([status])
  @@map("custom_invoices")
}

// =============================================================================
// REFERRAL CODES — standalone code registry (separate from EarlyAccessMember)
// =============================================================================

model ReferralCode {
  id         String    @id @default(cuid())
  code       String    @unique
  // generated | sent | used | expired
  status     String    @default("generated")
  label      String?
  assignedTo String?   // email address this code was sent to
  usedBy     String?   // email address who signed up with this code
  usedAt     DateTime?
  expiresAt  DateTime?
  revokedAt  DateTime?
  createdBy  String?   // platform admin user id
  source     String?   // e.g. 'ethdenver-batch', 'manual', 'csv-import'
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([status])
  @@index([assignedTo])
  @@map("referral_codes")
}
