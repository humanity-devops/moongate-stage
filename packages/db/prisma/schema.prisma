// =============================================================================
// CROWDFUNDING
// =============================================================================

// A community campaign where an entity competes for a sponsorship package.
// Multiple campaigns can run for the same item. The first to reach goalAmount wins.
model CrowdfundCampaign {
  id                String    @id @default(cuid())
  tenantId          String
  eventId           String
  itemId            String

  // The applying entity
  entityName        String
  entityDescription String?
  entityWebsite     String?
  contactName       String
  contactEmail      String

  // Funding goal = item list price (or custom for request_only items)
  goalAmount        Decimal   @db.Decimal(12, 2)
  raisedAmount      Decimal   @default(0) @db.Decimal(12, 2)
  currency          String    @default("USD")

  // Campaign window
  deadline          DateTime
  // active | won | lost | expired | cancelled
  status            String    @default("active")
  wonAt             DateTime?

  // Approval workflow: pending | approved | rejected
  approvalStatus    String    @default("pending")
  approvedBy        String?
  approvedAt        DateTime?
  rejectionReason   String?
  // M6: verification status: none | verification_pending | verified | rejected
  verificationStatus String   @default("none")

  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  tenant                Tenant                         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  event                 Event                          @relation(fields: [eventId], references: [id], onDelete: Cascade)
  item                  SponsorItem                    @relation(fields: [itemId], references: [id], onDelete: Cascade)
  contributions         CrowdfundContribution[]
  verificationRequests  CrowdfundVerificationRequest[]

  @@index([tenantId])
  @@index([eventId])
  @@index([itemId])
  @@index([status])
  @@map("crowdfund_campaigns")
}

// =============================================================================
// KYC / PARTNER ONBOARDING
// =============================================================================

// Per-tenant configuration: which fields/docs are required for KYC.
model KycConfig {
  id        String   @id @default(cuid())
  tenantId  String   @unique
  fields    Json     // Array of { key, label, type: 'text'|'file'|'select', required, options? }
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant      Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  submissions KycSubmission[]

  @@map("kyc_configs")
}

// One KYC submission per bid/order after acceptance/payment.
model KycSubmission {
  id          String    @id @default(cuid())
  tenantId    String
  kycConfigId String
  bidId       String?   @unique
  orderId     String?   @unique
  contactId   String?
  // not_started | submitted | approved | rejected | needs_more_info
  status      String    @default("not_started")
  data        Json?     // Submitted field values (non-file)
  reviewedBy  String?
  reviewedAt  DateTime?
  reviewNotes String?
  templateId  String?   // optional: linked KycFormTemplate
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  config       KycConfig      @relation(fields: [kycConfigId], references: [id])
  notes        KycNote[]
  auditEntries KycAuditEntry[]
  formRequests KycFormRequest[]

  @@index([tenantId])
  @@index([status])
  @@map("kyc_submissions")
}

// =============================================================================
// ANALYTICS
// =============================================================================

model AnalyticsEvent {
  id         String   @id @default(cuid())
  tenantId   String?
  // page_viewed | package_viewed | deck_viewed | cta_click | auth_redirect | bid_milestone
  eventType  String
  userId     String?  // null for anonymous
  sessionId  String?
  resourceId String?  // event/item/deck id being tracked
  resourceType String? // event | sponsor_item | deck
  referrer   String?
  utmSource  String?
  utmMedium  String?
  utmCampaign String?
  device     String?  // mobile | desktop | tablet
  country    String?
  // Extra key/value pairs (page path, bid amount, etc.)
  metadata   Json?
  // Anonymized after retention period: user_id nulled out
  anonymizedAt DateTime?
  createdAt  DateTime @default(now())

  @@index([tenantId, eventType])
  @@index([tenantId, createdAt])
  @@index([resourceId, resourceType])
  @@index([createdAt])
  @@map("analytics_events")
}

// An individual pledge/contribution to a crowdfund campaign.
model CrowdfundContribution {
  id               String   @id @default(cuid())
  campaignId       String
  contributorName  String
  contributorEmail String
  message          String?
  amount           Decimal  @db.Decimal(12, 2)
  currency         String   @default("USD")
  userId           String?
  orderId          String?  @unique
  // pending_payment | confirmed | refunded | cancelled
  status           String   @default("confirmed")
  createdAt        DateTime @default(now())

  campaign CrowdfundCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId])
  @@index([userId])
  @@map("crowdfund_contributions")
}

// =============================================================================
// PROPOSALS (custom sponsorship proposals submitted by sponsors)
// =============================================================================

model Proposal {
  id           String   @id @default(cuid())
  tenantId     String
  eventId      String
  contactName  String
  contactEmail String
  companyName  String
  // draft | submitted | under_review | accepted | rejected
  status       String   @default("draft")
  totalBudget  Decimal  @db.Decimal(12, 2)
  currency     String   @default("USD")
  notes        String?
  // Snapshot of the package builder output (array of component configs)
  packageData  Json?
  reviewedById String?
  reviewedAt   DateTime?
  rejectedReason String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  event  Event          @relation(fields: [eventId], references: [id], onDelete: Cascade)
  items  ProposalItem[]

  @@index([tenantId])
  @@index([eventId])
  @@index([status])
  @@index([contactEmail])
  @@map("proposals")
}

model ProposalItem {
  id          String  @id @default(cuid())
  proposalId  String
  itemId      String?   // optional link to an existing SponsorItem
  label       String
  description String?
  quantity    Int     @default(1)
  unitPrice   Decimal @db.Decimal(12, 2)
  total       Decimal @db.Decimal(12, 2)
  sortOrder   Int     @default(0)

  proposal Proposal    @relation(fields: [proposalId], references: [id], onDelete: Cascade)

  @@index([proposalId])
  @@map("proposal_items")
}

// =============================================================================
// OUTREACH (organizer contact database + invite pipeline)
